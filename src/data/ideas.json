[
  {
    "id": "idea-2026-03-05-rec-audit",
    "title": "Reverse Engineering Recommendation Algorithms",
    "description": "Создать систему, которая через обратное моделирование рекомендаций (inverse modeling) реконструирует алгоритмический профиль пользователя. По рекомендациям платформ (YouTube, TikTok, Netflix, LinkedIn) восстанавливается скрытый user embedding — приближённое представление того, как алгоритм \"видит\" пользователя. Это позволяет аудитировать рекомендательные системы на предмет bias, манипуляций и информационных пузырей. Pipeline: сбор рекомендаций → кодирование контента в embeddings → восстановление user vector (argmax similarity) → интерпретация в topics/interests/clusters. Актуально в контексте EU Digital Services Act и AI Act. По сути — nmap для рекомендательных систем.",
    "status": "idea",
    "results": null,
    "repoLink": null,
    "tags": [
